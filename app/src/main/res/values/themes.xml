<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        BATON base theme.
        - Parent: android:Theme.Material.Light.NoActionBar — built into the Android
          framework from API 21+, no AppCompat dependency required.
        - windowBackground is overridden to #070B14 (BatonBackground) so the
          "Light" parent has no visible effect — launch shows a dark canvas
          immediately, preventing a white flash before Compose draws its first frame.
        - Status/nav bar transparency is applied at runtime by Activity.enableEdgeToEdge();
          no XML item needed here.
    -->
    <style name="Theme.Baton" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">#0F1623</item>
        <item name="android:windowAnimationStyle">@null</item>
    </style>

    <!-- Splash theme using the AndroidX SplashScreen library -->
    <style name="Theme.Baton.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0F1623</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.Baton</item>
    </style>

</resources>
